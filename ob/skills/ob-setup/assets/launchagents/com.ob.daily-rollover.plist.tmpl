<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.ob.daily-rollover</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__OB__/ob-daily-rollover.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>5</integer><key>Minute</key><integer>30</integer></dict>
  <key>ProcessType</key><string>Background</string>
  <key>StandardOutPath</key><string>__OB__/logs/daily-rollover.log</string>
  <key>StandardErrorPath</key><string>__OB__/logs/daily-rollover.log</string>
</dict>
</plist>
